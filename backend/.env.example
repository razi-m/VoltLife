# Database connection URL (Supabase PostgreSQL Connection Pooler)
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# Example: postgresql://postgres.<ref>:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Demo key for reset/replay routes
DEMO_KEY=volt_secret_key

# Base URLs
PUBLIC_BASE_URL=http://localhost:8000
PUBLIC_FRONTEND_URL=http://localhost:3000

# Telemetry pacing speed (seconds per battery)
PACE_S=0.15

# Autonomy mode (automatically approves recommendations)
AUTONOMY_MODE=true

# Path to the versioned ML model bundle (stub used until ML phase swap)
MODEL_PATH=app/ml/models/model_v1.pkl

# Dedicated test database - REQUIRED to run pytest.
# Must point at a SEPARATE database from DATABASE_URL: the test suite drops/wipes tables.
TEST_DATABASE_URL=
