# Database connection URL (Supabase PostgreSQL Direct Connection)
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# Example: postgresql://postgres:[PASSWORD]@db.lzflstkuwyhxujmalpoe.supabase.co:5432/postgres
DATABASE_URL=

# Demo key for reset/replay routes
DEMO_KEY=volt_secret_key

# Base URLs
PUBLIC_BASE_URL=http://localhost:8000
PUBLIC_FRONTEND_URL=http://localhost:3000

# Telemetry pacing speed (seconds per battery)
PACE_S=0.15

# Autonomy mode (automatically approves recommendations)
AUTONOMY_MODE=true

# Path to the versioned ML model bundle (stub used until ML phase swap)
MODEL_PATH=app/ml/models/model_v1.pkl

# Dedicated test database - REQUIRED to run pytest.
# Must point at a SEPARATE database from DATABASE_URL: the test suite drops/wipes tables.
TEST_DATABASE_URL=

# Gemini API Key (Phase 6)
GEMINI_API_KEY=

# n8n Orchestration (Phase 10)
N8N_ENABLED=false
N8N_WEBHOOK_URL=
BACKEND_BASE_URL=http://localhost:8000

# Razorpay payment (test mode). LEAVE BLANK for the demo -> keyless MOCK checkout (no real money).
# Provide rzp_test_ keys to use the real Razorpay test Checkout. Stripe is retained until the
# Razorpay path is verified (do not remove Stripe yet).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=


